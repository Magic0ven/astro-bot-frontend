# Astro-Bot Dashboard API — env example
# Copy to .env and set as needed.

# Path to the astro-bot repo (signals, logs, assets_dna)
BOT_DIR=/path/to/astro-bot

# ── Database (optional) ───────────────────────────────────────────────────────
# When set, uses Postgres instead of local JSON/SQLite
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Railway provisioning (optional) ───────────────────────────────────────────
# RAILWAY_API_KEY=
# RAILWAY_PROJECT_ID=
# RAILWAY_ENVIRONMENT_ID=
# BOT_TEMPLATE_SERVICE_ID=
